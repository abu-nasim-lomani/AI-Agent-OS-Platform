# ── Local development (docker-compose মান) ──────────────────────────
# Copy: cp .env.example .env  — .env কখনো commit হবে না

# Postgres (pgvector)
DATABASE_URL=postgresql://agentos:agentos_dev@localhost:5432/agentos

# Redis — দুই instance, এক নয় (Architecture Review A1, docs/13 §Q3)
REDIS_CACHE_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6380

# Object storage (MinIO local, S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=agentos
S3_SECRET_KEY=agentos_dev
S3_BUCKET=knowledge

# Services
API_PORT=4000
AI_SERVICE_URL=http://localhost:8000
JWT_SECRET=dev-only-change-me

# LLM providers — gateway-র key pool (docs/05 §3)
# Production-এ secret manager থেকে; .env শুধু local dev
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Embeddings (dimension pin: db/migrations/0001 -এর vector() এর সাথে মিলতে হবে)
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024

# Cost guardrails (docs/10 §6)
DAILY_LLM_BUDGET_USD_GLOBAL=20
